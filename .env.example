# ============================================================
# 동천교회 홈페이지 환경 변수 예시
# 복사하여 .env 로 이름을 바꾸고 실제 값을 채워 넣으세요.
# .env 파일은 절대 저장소에 커밋하지 마세요.
# ============================================================

# ---- 데이터베이스 ----
DATABASE_URL="mysql://user:password@localhost:3306/dongcheon"

# ---- 인증 ----
NEXTAUTH_URL="http://localhost:3000"
# openssl rand -hex 32 결과를 붙여넣으세요
NEXTAUTH_SECRET="<openssl rand -hex 32>"

# ---- 사이트 설정 ----
SITE_NAME="동천교회"
SITE_URL="http://localhost:3000"
UPLOAD_DIR="./data"
# 업로드 최대 크기(바이트). 기본 10MB
MAX_UPLOAD_SIZE=10485760

# ---- 이메일 (Gmail 앱 비밀번호 기준) ----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="동천교회 <noreply@pkistdc.net>"

# ---- CAPTCHA HMAC 시크릿 ----
# openssl rand -hex 32 결과를 붙여넣으세요
CAPTCHA_SECRET="<openssl rand -hex 32>"

# ---- 외부 링크 (NEXT_PUBLIC_* 는 빌드 시 클라이언트에 노출됨) ----
NEXT_PUBLIC_YOUTUBE_LIVE_URL=""
NEXT_PUBLIC_FAITH_STUDY_URL=""
NEXT_PUBLIC_SINPUNG_CHURCH_URL=""
NEXT_PUBLIC_SONYANGWON=""
NEXT_PUBLIC_REPLAY_URL=""

# ---- 선택 사항 ----
# 음성 받아쓰기(Whisper) — 설치된 경우에만
# WHISPER_VENV="~/whisper-env"
# WHISPER_BIN="~/whisper-env/bin/whisper"

# 프로덕션에서 /admin/db/sql 사용을 허용하려면 true (기본: 비활성)
# ENABLE_SQL_CONSOLE=false
# ---- 기부자 주민번호 암호화 키 (국세청 서식 29호 영수증 발급용) ----
# AES-256-GCM. openssl rand -hex 32 결과를 그대로 붙여넣으세요 (64자).
# 키를 분실하면 이미 저장된 주민번호는 복구 불가 — 안전 보관 필수.
RRN_ENCRYPTION_KEY="<openssl rand -hex 32>"
